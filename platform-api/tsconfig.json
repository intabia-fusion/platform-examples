{
    "compilerOptions": {
    "target": "esnext",
    "module": "node16",
    "moduleResolution": "node16",
    "declaration": true,
    "strict": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declarationMap": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "rootDir": "examples",
    "outDir": "./lib",
    "incremental": true,
    "isolatedModules": true
    }
}